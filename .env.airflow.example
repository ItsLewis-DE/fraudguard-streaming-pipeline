# Local development only. Copy this file to .env.airflow and change secrets
# before exposing Airflow outside localhost.
AIRFLOW_IMAGE_NAME=fraudguard-airflow:3.2.2
AIRFLOW_UID=1000
AIRFLOW_PORT=8084
AIRFLOW_PARALLELISM=2
AIRFLOW_MAX_ACTIVE_TASKS_PER_DAG=2
COMPOSE_IGNORE_ORPHANS=true

AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_FERNET_KEY=hgPKSTYIPpMXRW2s03MChhIa0FHLryflFNzG4FO1164=
AIRFLOW_API_JWT_SECRET=fraudguard-local-jwt-secret-change-me

# MinIO root credentials are used only by the one-shot provisioning service.
# Airflow and its DAGs use the separate service account below.
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio-secret
MINIO_AIRFLOW_USER=fraudguard
MINIO_AIRFLOW_PASSWORD=fraudguard-secret

# docker-compose.yml uses these values to build the clickhouse_http
# Airflow connection. Keep them identical to the ClickHouse service settings.
CLICKHOUSE_DB=fraudguard
CLICKHOUSE_USER=fraudguard
CLICKHOUSE_PASSWORD=fraudguard-secret
CLICKHOUSE_LOADER_USER=fraudguard_loader
CLICKHOUSE_LOADER_PASSWORD=replace-with-loader-password
CLICKHOUSE_SUPERSET_PASSWORD=replace-with-superset-password
